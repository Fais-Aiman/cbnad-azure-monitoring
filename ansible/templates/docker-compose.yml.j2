version: "3.8"

services:
  postgres:
    image: postgres:15-alpine
    container_name: cbnad-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ zabbix_db_name }}
      POSTGRES_USER: {{ zabbix_db_user }}
      POSTGRES_PASSWORD: {{ zabbix_db_password }}
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - cbnad-net

  zabbix-server:
    image: zabbix/zabbix-server-pgsql:ubuntu-6.4-latest
    container_name: cbnad-zabbix-server
    restart: unless-stopped
    depends_on:
      - postgres
    environment:
      DB_SERVER_HOST: postgres
      POSTGRES_DB: {{ zabbix_db_name }}
      POSTGRES_USER: {{ zabbix_db_user }}
      POSTGRES_PASSWORD: {{ zabbix_db_password }}
    ports:
      - "10051:10051"
    networks:
      - cbnad-net

  zabbix-web:
    image: zabbix/zabbix-web-nginx-pgsql:ubuntu-6.4-latest
    container_name: cbnad-zabbix-web
    restart: unless-stopped
    depends_on:
      - postgres
      - zabbix-server
    environment:
      DB_SERVER_HOST: postgres
      POSTGRES_DB: {{ zabbix_db_name }}
      POSTGRES_USER: {{ zabbix_db_user }}
      POSTGRES_PASSWORD: {{ zabbix_db_password }}
      ZBX_SERVER_HOST: zabbix-server
      PHP_TZ: Asia/Kuala_Lumpur
    ports:
      - "8080:8080"
    networks:
      - cbnad-net

  zabbix-agent2:
    image: zabbix/zabbix-agent2:ubuntu-6.4-latest
    container_name: cbnad-zabbix-agent2
    restart: unless-stopped
    depends_on:
      - zabbix-server
    environment:
      ZBX_SERVER_HOST: zabbix-server
      ZBX_HOSTNAME: cbnad-vm01
    ports:
      - "10050:10050"
    networks:
      - cbnad-net

  node-exporter:
    image: quay.io/prometheus/node-exporter:v1.8.2
    container_name: cbnad-node-exporter
    network_mode: host
    pid: host
    restart: unless-stopped
    volumes:
      - /:/host:ro,rslave
    command:
      - --path.rootfs=/host

  prometheus:
    image: prom/prometheus:latest
    container_name: cbnad-prometheus
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
    ports:
      - "9090:9090"
    volumes:
      - /opt/cbnad/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - /opt/cbnad/alerts.yml:/etc/prometheus/alerts.yml:ro
      - prometheus-data:/prometheus
    networks:
      - cbnad-net

  grafana:
    image: grafana/grafana-oss:latest
    container_name: cbnad-grafana
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: {{ grafana_admin_user }}
      GF_SECURITY_ADMIN_PASSWORD: {{ grafana_admin_password }}
    ports:
      - "3000:3000"
    volumes:
      - grafana-data:/var/lib/grafana
    networks:
      - cbnad-net

volumes:
  postgres-data:
  prometheus-data:
  grafana-data:

networks:
  cbnad-net:
    driver: bridge
